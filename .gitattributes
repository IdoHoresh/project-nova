# Normalize all text files to LF in the repo, regardless of OS.
# Prevents CRLF ghost diffs if a contributor on Windows touches the repo.
* text=auto eol=lf

# ─── source code ───────────────────────────────────────────────────────────
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# ─── data + config ─────────────────────────────────────────────────────────
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf
*.lock text eol=lf

# ─── docs ──────────────────────────────────────────────────────────────────
*.md text eol=lf
*.txt text eol=lf

# ─── shell + scripting ─────────────────────────────────────────────────────
*.sh text eol=lf
*.bash text eol=lf

# ─── lockfiles — treat as binary so diffs stay sane ────────────────────────
pnpm-lock.yaml binary
package-lock.json binary
uv.lock binary

# ─── images + binary assets — never normalize ──────────────────────────────
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.pdf binary

# ─── Android / Unity build artifacts ───────────────────────────────────────
*.apk binary
*.aab binary
*.so binary
