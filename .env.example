# Project Nova — environment template
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values. NEVER commit .env.
# .env is in .gitignore. Run `git status` after creating .env to confirm
# it does NOT appear in the file list.
#
# All real secrets MUST come from environment variables.
# Code MUST NOT hardcode any of the values below.
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED — Anthropic API key (Claude with vision)
# Get one at https://console.anthropic.com/
# Format: sk-ant-...
ANTHROPIC_API_KEY=

# OPTIONAL — alternate VLM providers (only if you swap from Claude)
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# OPTIONAL — model overrides
# Defaults are set in nova-agent/src/nova_agent/config.py
# CLAUDE_MODEL=claude-opus-4-7
# CLAUDE_VISION_MODEL=claude-opus-4-7

# REQUIRED — paths to local data stores
# Default to nova-agent/data/ if unset
# NOVA_SQLITE_PATH=./data/nova.db
# NOVA_LANCEDB_PATH=./data/lancedb

# REQUIRED — emulator and ADB
# Path to adb binary; usually /usr/local/bin/adb on macOS
# ADB_PATH=adb
# Emulator device ID; run `adb devices` to find it
# ADB_DEVICE_ID=emulator-5554

# REQUIRED — WebSocket server for the brain panel
# NOVA_WS_HOST=127.0.0.1
# NOVA_WS_PORT=8765

# OPTIONAL — logging level (DEBUG / INFO / WARNING / ERROR)
# NOVA_LOG_LEVEL=INFO

# OPTIONAL — cost guardrails for development
# Daily VLM spend cap in USD (raises an error before exceeding)
# NOVA_DAILY_BUDGET_USD=20

# ─────────────────────────────────────────────────────────────────────────
# Security checklist before running:
#   1. Confirm `git status` does NOT list .env
#   2. Confirm `git ls-files | grep -i env` only shows .env.example
#   3. Run `git diff --cached` before every commit; scan for secrets
#   4. If you ever accidentally commit a key, rotate it IMMEDIATELY
#      at https://console.anthropic.com/ — don't try to "git rebase" it away
# ─────────────────────────────────────────────────────────────────────────
